{
  "name": "octane-playground",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "A scratch space for playing with Octane, a fast TypeScript-first UI framework.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jkup/octane-playground.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
