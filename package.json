    "postinstall": "node scripts/patch-octane-volar.mjs",
    "typecheck": "tsrx-tsc --noEmit -p tsconfig.json",
    "format": "prettier --write ."
  },
  "dependencies": {
    "octane": "^0.1.10"
  },
  "devDependencies": {
    "@tsrx/prettier-plugin": "^0.3.103",
    "@tsrx/typescript-plugin": "^0.3.103",
    "prettier": "^3.9.5",
    "typescript": "~5.9.3",
    "vite": "^8.1.5"
  }
